generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  PENDING_VERIFICATION
  SUSPENDED
  DELETED
}

enum RoleKey {
  PARENT
  SELLER
  ORGANIZER
  EXPERT
  PARTNER
  MUNICIPALITY_USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
  SYSTEM
}

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  emailVerifiedAt   DateTime?
  name              String?
  avatarUrl         String?
  status            UserStatus @default(PENDING_VERIFICATION)
  preferredLanguage String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?
  roles             UserRole[] @relation("UserRoleAssignments")
  assignedRoles     UserRole[] @relation("UserRoleAssignedBy")
  auditLogs         AuditLog[] @relation("AuditLogActor")

  @@index([status])
}

model Role {
  id          String     @id @default(cuid())
  key         RoleKey    @unique
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  users       UserRole[] @relation("RoleUserAssignments")
}

model UserRole {
  id           String    @id @default(cuid())
  userId       String
  roleId       String
  assignedById String?
  assignedAt   DateTime  @default(now())
  revokedAt    DateTime?
  user         User      @relation("UserRoleAssignments", fields: [userId], references: [id])
  role         Role      @relation("RoleUserAssignments", fields: [roleId], references: [id])
  assignedBy   User?     @relation("UserRoleAssignedBy", fields: [assignedById], references: [id])

  @@index([userId])
  @@index([roleId])
  @@index([assignedById])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  String?
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  actor      User?    @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}
